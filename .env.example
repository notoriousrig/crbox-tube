# Copy to .env and fill in. .env is gitignored.

# --- Cloudflare Access ---
# Zero Trust team domain, e.g. "crbox.cloudflareaccess.com"
CF_ACCESS_TEAM_DOMAIN=crbox.cloudflareaccess.com
# Application AUD tag. Created when you add an Access app for tube.crbox.ca.
# Find it under Access -> Applications -> your app -> Overview.
# Leave empty to bypass auth in local dev.
CF_ACCESS_AUD=

# --- App ---
LOG_LEVEL=INFO

# RSS polling
POLL_INTERVAL_MINUTES=120
POLL_CONCURRENCY=8

# Nightly SQLite backup (server local time, 0-23) + retention
BACKUP_HOUR=4
BACKUP_KEEP_DAYS=30

# Drop video rows older than this; preserves saved/watched marks regardless.
# Set to 0 to keep everything forever.
VIDEO_RETENTION_DAYS=180

# --- Phase 2 (optional) ---
# YouTube Data API v3 key. Only used if set; enables duration-based shorts
# filtering and topic/keyword discovery. Free tier: 10k units/day.
YOUTUBE_API_KEY=
